{
    "name": "foodieneers/laravel-seo",
    "description": "A package to handle the SEO in any Laravel application, big or small.",
    "keywords": [
        "Foodieneers",
        "laravel",
        "laravel-seo"
    ],
    "homepage": "https://github.com/foodieneers/laravel-seo",
    "license": "MIT",
    "authors": [
        {
            "name": "Paride Azzari",
            "email": "paride21azzari@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.11|^12.0",
        "spatie/laravel-package-tools": "^1.9.2",
        "spatie/schema-org": "^4.0"
    },
    "require-dev": {
        "foodieneers/laravel-devtools": "^1.0",
        "nesbot/carbon": "^3.0",
        "orchestra/testbench": "^9.16|^10.0",
        "orchestra/testbench-core": "^9.1.4|^10.0"
    },
    "autoload": {
        "psr-4": {
            "Foodieneers\\Laravel\\SEO\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Foodieneers\\Laravel\\SEO\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:types": "vendor/bin/phpstan analyse --memory-limit=4G",
        "lint": [
            "vendor/bin/rector",
            "vendor/bin/pint"
        ],
        "test-coverage": "vendor/bin/pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Foodieneers\\Laravel\\SEO\\LaravelSEOServiceProvider"
            ],
            "aliases": {
                "SEOManager": "Foodieneers\\Laravel\\SEO\\Facades\\SEOManager"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
